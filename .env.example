# ============================================================
# nucleo-minisaas — variables de entorno
# Copiá este archivo a .env y completá. `npm run init:hijo` lo
# hace por vos (genera AUTH_SECRET y pregunta lo básico).
# Los NOMBRES de estas variables son un contrato de la flota:
# no los renombres — el tooling de flota depende de ellos.
# ============================================================

NODE_ENV=development

# --- Base de datos (Postgres) — DOS roles, no uno ---
# DATABASE_URL = runtime de la app: rol SIN permisos de DDL (no puede alterar
#   el schema aunque comprometan la app). Pooler 6543 si usás Supabase.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nucleo_minisaas"
# DIRECT_URL = migraciones (prisma migrate en build/CLI): rol owner con DDL,
#   conexión directa (5432). En local ambos pueden ser postgres.
#   SQL para crear el rol de runtime: ver docs/01, "Split de roles de DB".
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nucleo_minisaas"
# Tests: DB exclusiva — el nombre DEBE contener "test" (guard en tests/setup.ts).
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nucleo_minisaas_test"

# --- Identidad de la app (branding, nada hardcodeado) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Mi Sistema"
NEXT_PUBLIC_INSTITUCION_NOMBRE="Mi Organización"

# --- Auth (NextAuth v5) ---
# Obligatorio en producción, mínimo 32 caracteres. Generar: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Admin inicial (lo crea `npm run db:seed`, idempotente) ---
BOOTSTRAP_ADMIN_EMAIL="admin@misistema.local"
BOOTSTRAP_ADMIN_PASSWORD="cambiar123"
BOOTSTRAP_ADMIN_NOMBRE="Admin"
BOOTSTRAP_ADMIN_APELLIDO="Inicial"

# --- Email (Resend) ---
# Sin RESEND_API_KEY los emails se loguean a consola (driver "log", útil en dev).
RESEND_API_KEY=""
EMAIL_FROM="Mi Sistema <no-responder@misistema.com>"

# --- Storage de archivos ---
# "local" (carpeta uploads/, dev) | "supabase" (buckets privados, prod)
STORAGE_DRIVER="local"
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SECRET_KEY=""

# --- Monitoreo (opcional) ---
# Si definís SENTRY_DSN e instalás @sentry/nextjs, el logger lo usa (ver docs/01).
SENTRY_DSN=""
# Token del monitor de flota: habilita GET /api/health/flujos (chequeos de
# flujos críticos). Sin valor, el endpoint responde 404. Mismo valor que el
# secret FLOTA_TOKEN del repo flota. Generar: openssl rand -hex 24
FLOTA_TOKEN=""
