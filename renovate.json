{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":timezone(America/Argentina/Buenos_Aires)"],
  "labels": ["dependencias"],
  "prConcurrentLimit": 5,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["seguridad"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge de patches y minors de devDependencies con CI verde",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge de patches de dependencies con CI verde",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Next/React/Prisma/NextAuth: majors y minors siempre a mano",
      "matchPackageNames": ["next", "react", "react-dom", "prisma", "@prisma/client", "@prisma/adapter-pg", "next-auth"],
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false
    }
  ]
}
