// =====================================================================
// nucleo-minisaas — schema base
//
// KERNEL (no tocar en los hijos salvo parche del template):
//   Persona, Usuario, PasswordResetToken, Rol, Permiso, RolPermiso,
//   UsuarioRol, AuditLog, Documento.
//
// DOMINIO (zona custom de este sistema):
//   Cliente, Rubro, Ticket, ConfiguracionCapacidad.
//
// Convención de fechas: las "fechas calendario" se guardan a 00:00 UTC
// (ver src/core/lib/fechas.ts); los timestamps reales llevan hora real.
// =====================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================================
// KERNEL — identidad
// ========================================================

/// Entidad raíz: toda persona física del sistema. Los roles de dominio
/// (cliente, socia, paciente…) se modelan como relaciones, no duplicando
/// datos. `anonimizada` implementa el derecho de supresión (Ley 25.326):
/// se blanquea la PII pero se preservan los registros para estadística.
model Persona {
  id              String    @id @default(cuid())
  nombre          String
  apellido        String
  documento       String?   @unique
  email           String?
  telefono        String?
  fechaNacimiento DateTime?
  notas           String?

  anonimizada       Boolean   @default(false)
  fechaAnonimizacion DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario    Usuario?
  documentos Documento[]

  @@index([apellido, nombre])
}

/// Cuenta de acceso al sistema. Siempre pertenece a una Persona (1 a 1):
/// el nombre visible sale de ahí.
model Usuario {
  id              String    @id @default(cuid())
  personaId       String    @unique
  email           String    @unique
  passwordHash    String
  emailVerificado Boolean   @default(false)
  activo          Boolean   @default(true)
  ultimoLogin     DateTime?

  // Bloqueo por intentos fallidos (ver src/core/auth)
  intentosFallidos Int       @default(0)
  bloqueadoHasta   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persona     Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)
  roles       UsuarioRol[]
  resetTokens PasswordResetToken[]
  auditLogs   AuditLog[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  usuarioId String
  tokenHash String    @unique
  expiraEn  DateTime
  usadoEn   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

// ========================================================
// KERNEL — RBAC
// ========================================================

model Rol {
  id          String  @id @default(cuid())
  codigo      String  @unique
  nombre      String
  descripcion String?
  esSistema   Boolean @default(false)

  permisos RolPermiso[]
  usuarios UsuarioRol[]
}

model Permiso {
  id      String @id @default(cuid())
  modulo  String
  recurso String
  accion  String

  roles RolPermiso[]

  @@unique([modulo, recurso, accion])
}

enum ScopeTipo {
  GLOBAL
  PROPIO
}

model RolPermiso {
  id        String    @id @default(cuid())
  rolId     String
  permisoId String
  scope     ScopeTipo @default(GLOBAL)

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
}

model UsuarioRol {
  id        String  @id @default(cuid())
  usuarioId String
  rolId     String
  scopeId   String?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rolId, scopeId])
}

// ========================================================
// KERNEL — auditoría y archivos
// ========================================================

/// Registro de auditoría (obligatorio en mutaciones sobre datos personales).
/// Se escribe vía registrarAuditoria() de src/core/lib/audit.ts — nunca a mano.
model AuditLog {
  id            String   @id @default(cuid())
  fecha         DateTime @default(now())
  usuarioId     String?
  ip            String?
  userAgent     String?
  modulo        String
  accion        String
  recursoTipo   String
  recursoId     String?
  valorAnterior Json?
  valorNuevo    Json?
  exito         Boolean  @default(true)
  detalle       String?

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([fecha])
  @@index([usuarioId])
  @@index([modulo, accion])
}

/// Contador de rate limiting con ventana fija (ver core/lib/rate-limit.ts).
/// En DB para que funcione igual en serverless (memoria no compartida).
model RateLimit {
  clave         String   @id
  contador      Int      @default(1)
  ventanaInicio DateTime @default(now())
}

/// Archivo adjunto a una persona (se sirve con URL firmada, ver core/storage).
model Documento {
  id            String   @id @default(cuid())
  personaId     String
  tipo          String
  nombre        String
  archivoUrl    String   @unique
  archivoNombre String
  archivoTamano Int
  notas         String?
  createdAt     DateTime @default(now())

  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId])
}

// ========================================================
// DOMINIO — Panel MiniSaaS (uso interno)
//
// Cliente = un negocio al que le opero un mini-SaaS (cuenta, NO Persona:
// Persona/Usuario del kernel quedan solo para el operador del panel).
// Ticket = el corazón: cada pedido de soporte con sus horas.
// Rubro = catálogo configurable. ConfiguracionCapacidad = singleton que
// deriva el umbral de horas/cliente/mes.
//
// Futuro (v2/v3, no en el MVP): Mejora (roadmap), Prospecto (pipeline),
// Pago (suscripción Mercado Pago). El modelo queda abierto a sumarlas.
// ========================================================

/// Estado comercial del cliente. `baja` es lógica: preserva el historial de
/// tickets para estadística (no se borra la cuenta).
enum EstadoCliente {
  activo
  pausado
  baja
}

/// Estado de cobranza. En el MVP se carga a mano; en v2 lo actualiza el
/// webhook de Mercado Pago. Alimenta el semáforo de riesgo.
enum EstadoPago {
  al_dia
  demorado
  vencido
}

/// Clasificación del pedido de soporte. Regla de negocio: bug siempre gratis;
/// feature >5h se cotiza aparte (la validación de scope llega en v2).
enum TipoTicket {
  bug
  ajuste
  feature
  consulta
}

model Cliente {
  id               String        @id @default(cuid())
  negocio          String
  rubroId          String?
  sistema          String? // qué mini-SaaS le entregué
  contactoNombre   String?
  contactoEmail    String?
  contactoTelefono String?
  fechaAlta        DateTime // fecha calendario (00:00 UTC)
  abonoMensual     Float         @default(100)
  moneda           String        @default("USD")
  estado           EstadoCliente @default(activo)
  estadoPago       EstadoPago    @default(al_dia)
  ultimaActividad  DateTime? // proxy de "usa el sistema" (se explota en v2/v3)
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  rubro   Rubro?   @relation(fields: [rubroId], references: [id], onDelete: SetNull)
  tickets Ticket[]

  @@index([negocio])
  @@index([estado])
}

/// Catálogo configurable de rubros (gastronomía, retail, salud…).
model Rubro {
  id     String  @id @default(cuid())
  codigo String  @unique
  nombre String
  activo Boolean @default(true)
  orden  Int     @default(0)

  clientes Cliente[]
}

/// El corazón del panel: cada pedido/ticket con sus horas. `fecha` es un
/// timestamp real (cuándo se atendió). `horasHombre` es la métrica madre que
/// se compara contra el umbral; `tiempoIa` alimenta el % atendido por IA.
model Ticket {
  id           String     @id @default(cuid())
  clienteId    String
  tipo         TipoTicket
  descripcion  String?
  horasHombre  Float      @default(0)
  tiempoIa     Float      @default(0)
  automatizado Boolean    @default(false)
  fecha        DateTime   @default(now())
  createdAt    DateTime   @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([fecha])
}

/// Configuración de capacidad (fila única, id fijo "singleton"). El umbral de
/// horas por cliente se deriva: horasSoporteMes / clientesObjetivo.
model ConfiguracionCapacidad {
  id               String   @id @default("singleton")
  horasSoporteMes  Int      @default(120)
  clientesObjetivo Int      @default(60)
  updatedAt        DateTime @updatedAt
}
